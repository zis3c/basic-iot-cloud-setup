# Timezone used by most containers
TZ=Asia/Kuala_Lumpur

# Your public hostname (DuckDNS/your domain), without subdomain prefixes
# Example (DuckDNS): DOMAIN=yourname.duckdns.org
DOMAIN=example.duckdns.org

# Let's Encrypt account email (required for HTTPS certs)
LETSENCRYPT_EMAIL=you@example.com

# Traefik dashboard host (basic auth users live in traefik/auth/users)
TRAEFIK_SUBDOMAIN=traefik

# Public subdomains for apps (these become <subdomain>.<DOMAIN>)
PORTAINER_SUBDOMAIN=ops
NODERED_SUBDOMAIN=nodered
INFLUXDB_SUBDOMAIN=influx
GRAFANA_SUBDOMAIN=dash
ADMINER_SUBDOMAIN=adminer

# DuckDNS updater (SUBDOMAINS is comma-separated, without ".duckdns.org")
DUCKDNS_SUBDOMAINS=example
DUCKDNS_TOKEN=CHANGE_ME

# InfluxDB 2.x one-time bootstrap (do not reuse this token elsewhere)
INFLUXDB_ORG=ksc6493
INFLUXDB_BUCKET=iot
INFLUXDB_ADMIN_USER=admin
INFLUXDB_ADMIN_PASSWORD=CHANGE_ME
INFLUXDB_ADMIN_TOKEN=CHANGE_ME

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# MariaDB
MARIADB_ROOT_PASSWORD=CHANGE_ME
MARIADB_DATABASE=iot
MARIADB_USER=iot
MARIADB_PASSWORD=CHANGE_ME

# MQTT service credentials (used by setup script + ESP32 clients)
MQTT_DEVICE_USER=esp32dht
MQTT_DEVICE_PASSWORD=CHANGE_ME
MQTT_NODERED_USER=nodered
MQTT_NODERED_PASSWORD=CHANGE_ME
MQTT_IOTUSER=iotuser
MQTT_IOTUSER_PASSWORD=CHANGE_ME
